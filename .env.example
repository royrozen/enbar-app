# Client (Vite) — safe to expose in the bundle
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server only (Vercel serverless functions, /api) — NEVER prefix with VITE_,
# never reference from src/. Set these in the Vercel project settings.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SIGNWELL_API_KEY=
SIGNWELL_TEST_MODE=true
# From the SignWell dashboard when the webhook (api/webhooks/signwell.js) is
# registered — used as the HMAC key for event hash verification, NOT the API key.
SIGNWELL_WEBHOOK_ID=
